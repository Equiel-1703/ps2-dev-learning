{
    "configurations": [
        {
            "name": "PS2 Homebrew",
            "includePath": [
                "${workspaceFolder}/**",
                "${env:PS2SDK}/ee/include/**",
                "${env:PS2SDK}/common/include/**",
                "${env:PS2SDK}/../ee/mips64r5900el-ps2-elf/include/**"
            ],
            "defines": [
                "_EE"
            ],
            "compilerPath": "${env:PS2SDK}/../ee/bin/mips64r5900el-ps2-elf-gcc",
            "cStandard": "c99",
            "cppStandard": "gnu++14",
            "intelliSenseMode": "linux-gcc-x64"
        }
    ],
    "version": 4
}